#include <stdio.h>
#include <string.h>

#define MAX 100000

char stack[MAX];
int top = -1;

void push(char c) {
stack[++top] = c;
}

char pop() {
if (top == -1)
return '\0';
return stack[top--];
}

int isMatching(char open, char close) {
if (open == '(' && close == ')') return 1;
if (open == '{' && close == '}') return 1;

if (open == '[' && close == ']') return 1;
return 0;
}

int isBalanced(char s[]) {
for (int i = 0; s[i] != '\0'; i++) {

if (s[i] == '(' || s[i] == '{' || s[i] == '[') {
push(s[i]);
}
else {
char topChar = pop();
if (!isMatching(topChar, s[i])) {
return 0;
}
}
}

return (top == -1);
}

